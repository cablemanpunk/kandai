					<li><a href="https://t.me/kandai_community" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-electric-green transition-colors">Сообщество</a></li>
					<li><a href="https://t.me/kandai_systems" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-electric-green transition-colors">Канал</a></li>
					<li><a href="mailto:support@kandai.systems" class="text-gray-400 hover:text-electric-green transition-colors">Email</a></li>
				</ul>
			</div>
		</div>

		<!-- Bottom Bar -->
		<div class="border-t border-dark-border mt-8 pt-8">
			<div class="flex flex-col md:flex-row justify-between items-center">
				<p class="text-gray-400 text-sm mb-4 md:mb-0">
					© 2024 KandAI Systems. Все права защищены.
				</p>
				<div class="flex items-center space-x-6 text-sm text-gray-400">
					<span>Авторский проект</span>
					<span>•</span>
					<span>Проверено в реальном бизнесе</span>
