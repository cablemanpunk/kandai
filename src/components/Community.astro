---
// Community section component
---

<section id="community" class="py-20 relative">
	<div class="container mx-auto px-4">
		<!-- Section Header -->
		<div class="text-center mb-16">
			<h2 class="text-4xl md:text-5xl font-bold mb-6">
				<span class="gradient-text">Сообщество и ресурсы</span>
			</h2>
			<p class="text-xl text-gray-400 max-w-2xl mx-auto">
				Присоединяйтесь к сообществу селлеров и получайте эксклюзивные материалы
			</p>
		</div>

		<!-- Community Cards -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
			<!-- Telegram Group -->
			<div class="glass-card rounded-2xl p-8 border border-dark-border hover:border-electric-green/50 transition-all hover:shadow-2xl hover:shadow-electric-green/10 group relative overflow-hidden">
				<!-- Background decoration -->
				<div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-2xl"></div>
				
				<div class="relative z-10">
					<div class="flex items-center mb-6">
						<div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center text-2xl mr-4 group-hover:scale-110 transition-transform">
							💬
						</div>
						<div>
							<h3 class="text-2xl font-bold text-white mb-1">Telegram Группа</h3>
							<p class="text-gray-400">Сообщество для продавцов</p>
						</div>
					</div>
					
					<p class="text-gray-300 mb-6">
						Делимся опытом и кейсами по автоматизации маркетплейсов. 
						Задавайте вопросы и получайте ответы от опытных селлеров.
					</p>

					<div class="flex items-center justify-between mb-6">
						<div class="flex items-center space-x-4 text-sm text-gray-400">
							<div class="flex items-center">
								<svg class="w-4 h-4 mr-1 text-electric-green" fill="currentColor" viewBox="0 0 20 20">
									<path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
								</svg>
								<span>500+ участников</span>
							</div>
							<div class="flex items-center">
								<svg class="w-4 h-4 mr-1 text-electric-green" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
								</svg>
								<span>24/7 поддержка</span>
							</div>
						</div>
					</div>

					<a href="https://t.me/kandai_community" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-semibold rounded-lg transform transition-all hover:scale-105 hover:shadow-lg w-full justify-center">
						<svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.56c-.21 2.26-1.13 7.69-1.6 10.22-.2 1.08-.59 1.44-.97 1.47-.82.07-1.45-.54-2.23-1.07-1.24-.81-1.94-1.32-3.14-2.11-1.39-.9-.49-1.39.3-2.2.21-.22 3.83-3.51 3.91-3.81.01-.04.01-.18-.07-.26s-.2-.04-.28-.02c-.12.03-2.09 1.33-5.91 3.91-.56.38-1.06.57-1.52.56-.5-.01-1.46-.28-2.18-.51-.88-.28-1.57-.43-1.51-.91.03-.25.39-.51 1.07-.78 4.18-1.82 6.97-3.02 8.35-3.6 3.99-1.66 4.81-1.95 5.34-1.96.12 0 .38.03.55.17.14.12.18.28.2.44-.01.06.01.23 0 .36z"/>
						</svg>
						Присоединиться к группе
					</a>
				</div>
			</div>

			<!-- Telegram Channel -->
			<div class="glass-card rounded-2xl p-8 border border-dark-border hover:border-electric-green/50 transition-all hover:shadow-2xl hover:shadow-electric-green/10 group relative overflow-hidden">
				<!-- Background decoration -->
				<div class="absolute top-0 right-0 w-32 h-32 bg-green-500/10 rounded-full blur-2xl"></div>
				
				<div class="relative z-10">
					<div class="flex items-center mb-6">
						<div class="w-16 h-16 bg-gradient-to-br from-green-500 to-green-600 rounded-xl flex items-center justify-center text-2xl mr-4 group-hover:scale-110 transition-transform">
							📢
						</div>
						<div>
							<h3 class="text-2xl font-bold text-white mb-1">Telegram Канал</h3>
							<p class="text-gray-400">Новости KandAI Systems</p>
						</div>
					</div>
					
					<p class="text-gray-300 mb-6">
						Обновления и новые фишки. Первыми узнавайте о новых инструментах 
						и получайте эксклюзивные скидки.
					</p>

					<div class="flex items-center justify-between mb-6">
						<div class="flex items-center space-x-4 text-sm text-gray-400">
							<div class="flex items-center">
								<svg class="w-4 h-4 mr-1 text-electric-green" fill="currentColor" viewBox="0 0 20 20">
									<path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/>
									<path fill-rule="evenodd" d="M4 5a2 2 0 012-2 1 1 0 000 2H6a2 2 0 100 4h2a2 2 0 100-4h-.5a1 1 0 000-2H8a2 2 0 012-2h4a2 2 0 012 2v10a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/>
								</svg>
								<span>Еженедельные обновления</span>
							</div>
							<div class="flex items-center">
								<svg class="w-4 h-4 mr-1 text-electric-green" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z" clip-rule="evenodd"/>
								</svg>
								<span>Эксклюзивный контент</span>
							</div>
						</div>
					</div>

					<a href="https://t.me/kandai_systems" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-green-500 to-green-600 text-white font-semibold rounded-lg transform transition-all hover:scale-105 hover:shadow-lg w-full justify-center">
						<svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.56c-.21 2.26-1.13 7.69-1.6 10.22-.2 1.08-.59 1.44-.97 1.47-.82.07-1.45-.54-2.23-1.07-1.24-.81-1.94-1.32-3.14-2.11-1.39-.9-.49-1.39.3-2.2.21-.22 3.83-3.51 3.91-3.81.01-.04.01-.18-.07-.26s-.2-.04-.28-.02c-.12.03-2.09 1.33-5.91 3.91-.56.38-1.06.57-1.52.56-.5-.01-1.46-.28-2.18-.51-.88-.28-1.57-.43-1.51-.91.03-.25.39-.51 1.07-.78 4.18-1.82 6.97-3.02 8.35-3.6 3.99-1.66 4.81-1.95 5.34-1.96.12 0 .38.03.55.17.14.12.18.28.2.44-.01.06.01.23 0 .36z"/>
						</svg>
						Подписаться на канал
					</a>
				</div>
			</div>
		</div>

		<!-- Additional Resources -->
		<div class="mt-16 text-center">
			<div class="glass-card rounded-2xl p-8 border border-dark-border max-w-2xl mx-auto">
				<h3 class="text-xl font-semibold text-white mb-4">Полезные ресурсы</h3>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
					<div class="text-center">
						<div class="text-2xl text-electric-green mb-2">📚</div>
						<p class="text-gray-300">База знаний</p>
					</div>
					<div class="text-center">
						<div class="text-2xl text-electric-green mb-2">🎥</div>
						<p class="text-gray-300">Видеоуроки</p>
					</div>
					<div class="text-center">
						<div class="text-2xl text-electric-green mb-2">🛠️</div>
						<p class="text-gray-300">Техподдержка</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
