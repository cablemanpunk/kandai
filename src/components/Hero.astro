---
// Hero section component
---

<section class="min-h-screen flex items-center justify-center relative overflow-hidden pt-20">
	<!-- Background Gradient -->
	<div class="absolute inset-0 bg-gradient-to-br from-dark-bg via-dark-bg to-dark-card">
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-accent-red/10 via-transparent to-transparent"></div>
	</div>

	<!-- Animated Grid Background -->
	<div class="absolute inset-0 opacity-20">
		<div class="h-full w-full bg-[linear-gradient(to_right,_#2A2A2A_1px,_transparent_1px),linear-gradient(to_bottom,_#2A2A2A_1px,_transparent_1px)] bg-[size:4rem_4rem]"></div>
	</div>

	<!-- Content -->
	<div class="relative z-10 container mx-auto px-4 text-center">
		<!-- Logo Section -->
		<div class="mb-8 flex justify-center">
			<div class="relative group">
				<div class="absolute inset-0 bg-gradient-to-r from-accent-red to-light-red rounded-2xl blur-xl opacity-50 group-hover:opacity-70 transition-opacity"></div>
				<div class="relative bg-gradient-to-br from-accent-red to-light-red rounded-2xl p-6 transform transition-transform group-hover:scale-105">
					<!-- Замените SVG на изображение если нужно -->
					<svg class="w-16 h-16 text-white" fill="currentColor" viewBox="0 0 24 24">
						<path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/>
					</svg>
					<!-- Или используйте изображение: -->
					<!-- <img src="/images/logo/kandai-logo-white.svg" alt="KandAI Systems" class="w-16 h-16" /> -->
				</div>
			</div>
		</div>

		<!-- Main Title -->
		<h1 class="text-5xl md:text-7xl font-bold mb-6">
			<span class="gradient-text">KandAI Systems</span>
			<br />
			<span class="text-3xl md:text-5xl text-gray-300 font-light">Экосистема автоматизации</span>
		</h1>

		<!-- Subtitle -->
		<p class="text-xl md:text-2xl text-gray-400 mb-8 max-w-3xl mx-auto leading-relaxed">
			для маркетплейсов и бизнеса
		</p>

		<!-- Main Description -->
		<div class="max-w-2xl mx-auto mb-12">
			<p class="text-lg text-gray-300 leading-relaxed">
				Создаю умные скрипты, ИИ-ботов и ПО, которые заменяют отдел контента и операционистов. 
				Проверенные решения для селлеров и системного бизнеса.
			</p>
		</div>

		<!-- CTA Button -->
		<div class="mb-16">
			<a href="#tools" class="inline-flex items-center px-8 py-4 gradient-button text-white font-bold text-lg rounded-full group">
				<span>Посмотреть все инструменты</span>
				<svg class="w-5 h-5 ml-2 transform transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
				</svg>
			</a>
		</div>

		<!-- Key Benefits -->
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
			<div class="glass-card rounded-xl p-6 border border-dark-border hover:border-accent-red/50 transition-colors">
				<div class="text-accent-red text-3xl mb-3">⚡</div>
				<h3 class="text-white font-semibold mb-2">Экономия времени</h3>
				<p class="text-gray-400 text-sm">Автоматизация рутинных задач до 90%</p>
			</div>
			<div class="glass-card rounded-xl p-6 border border-dark-border hover:border-accent-red/50 transition-colors">
				<div class="text-accent-red text-3xl mb-3">📈</div>
				<h3 class="text-white font-semibold mb-2">Масштабирование</h3>
				<p class="text-gray-400 text-sm">Растите в прибыли, а не в затратах</p>
			</div>
			<div class="glass-card rounded-xl p-6 border border-dark-border hover:border-accent-red/50 transition-colors">
				<div class="text-accent-red text-3xl mb-3">🤖</div>
				<h3 class="text-white font-semibold mb-2">ИИ технологии</h3>
				<p class="text-gray-400 text-sm">Современные решения для вашего бизнеса</p>
			</div>
		</div>
	</div>

	<!-- Scroll Indicator -->
	<div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
		<svg class="w-6 h-6 text-accent-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
		</svg>
	</div>
</section>
