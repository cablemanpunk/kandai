---
// Custom development section component
---

<section id="custom" class="py-20 relative">
	<div class="container mx-auto px-4">
		<!-- Section Header -->
		<div class="text-center mb-16">
			<h2 class="text-4xl md:text-5xl font-bold mb-6">
				<span class="gradient-text">Индивидуальная разработка</span>
			</h2>
			<p class="text-2xl text-gray-400 mb-8">Нужен уникальный инструмент?</p>
		</div>

		<!-- Main Content -->
		<div class="max-w-4xl mx-auto">
			<div class="glass-card rounded-2xl p-12 border border-dark-border relative overflow-hidden">
				<!-- Background decoration -->
				<div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-electric-green/10 to-transparent rounded-full blur-3xl"></div>
				<div class="absolute bottom-0 left-0 w-48 h-48 bg-gradient-to-tr from-neon-green/10 to-transparent rounded-full blur-2xl"></div>

				<div class="relative z-10">
					<p class="text-lg text-gray-300 mb-8 leading-relaxed">
						Разрабатываю ботов, скрипты и кастомное ПО под конкретные задачи вашего бизнеса. 
						От парсеров до сложных систем учета.
					</p>

					<!-- Services Grid -->
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
						<div class="flex items-start space-x-3">
							<div class="flex-shrink-0 w-8 h-8 bg-electric-green/20 rounded-lg flex items-center justify-center">
								<svg class="w-4 h-4 text-electric-green" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
							</div>
							<div>
								<h4 class="text-white font-semibold mb-1">Парсеры данных</h4>
								<p class="text-gray-400 text-sm">Сбор информации с любых источников</p>
							</div>
						</div>

						<div class="flex items-start space-x-3">
							<div class="flex-shrink-0 w-8 h-8 bg-electric-green/20 rounded-lg flex items-center justify-center">
								<svg class="w-4 h-4 text-electric-green" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
							</div>
							<div>
								<h4 class="text-white font-semibold mb-1">Автоматизация процессов</h4>
								<p class="text-gray-400 text-sm">Полное исключение ручного труда</p>
							</div>
						</div>

						<div class="flex items-start space-x-3">
							<div class="flex-shrink-0 w-8 h-8 bg-electric-green/20 rounded-lg flex items-center justify-center">
								<svg class="w-4 h-4 text-electric-green" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
							</div>
							<div>
								<h4 class="text-white font-semibold mb-1">ИИ-интеграции</h4>
								<p class="text-gray-400 text-sm">Умная обработка данных и контента</p>
							</div>
						</div>

						<div class="flex items-start space-x-3">
							<div class="flex-shrink-0 w-8 h-8 bg-electric-green/20 rounded-lg flex items-center justify-center">
								<svg class="w-4 h-4 text-electric-green" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
							</div>
							<div>
								<h4 class="text-white font-semibold mb-1">Системы учета</h4>
								<p class="text-gray-400 text-sm">Кастомные решения под ваш бизнес</p>
							</div>
						</div>
					</div>

					<!-- Process Steps -->
					<div class="mb-10">
						<h3 class="text-xl font-semibold text-white mb-6">Как мы работаем:</h3>
						<div class="grid grid-cols-1 md:grid-cols-4 gap-4">
							<div class="text-center">
								<div class="w-12 h-12 bg-gradient-to-br from-electric-green to-neon-green rounded-full flex items-center justify-center mx-auto mb-3 text-dark-bg font-bold">
									1
								</div>
								<p class="text-gray-300 text-sm">Анализ задачи</p>
							</div>
							<div class="text-center">
								<div class="w-12 h-12 bg-gradient-to-br from-electric-green to-neon-green rounded-full flex items-center justify-center mx-auto mb-3 text-dark-bg font-bold">
									2
								</div>
								<p class="text-gray-300 text-sm">Предложение решения</p>
							</div>
							<div class="text-center">
								<div class="w-12 h-12 bg-gradient-to-br from-electric-green to-neon-green rounded-full flex items-center justify-center mx-auto mb-3 text-dark-bg font-bold">
									3
								</div>
								<p class="text-gray-300 text-sm">Разработка</p>
							</div>
							<div class="text-center">
								<div class="w-12 h-12 bg-gradient-to-br from-electric-green to-neon-green rounded-full flex items-center justify-center mx-auto mb-3 text-dark-bg font-bold">
									4
								</div>
								<p class="text-gray-300 text-sm">Внедрение и поддержка</p>
							</div>
						</div>
					</div>

					<!-- CTA Button -->
					<div class="text-center">
						<a href="https://t.me/kandai_systems" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-electric-green to-neon-green text-dark-bg font-bold text-lg rounded-full transform transition-all hover:scale-105 hover:shadow-2xl hover:shadow-electric-green/25 group">
							<svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.56c-.21 2.26-1.13 7.69-1.6 10.22-.2 1.08-.59 1.44-.97 1.47-.82.07-1.45-.54-2.23-1.07-1.24-.81-1.94-1.32-3.14-2.11-1.39-.9-.49-1.39.3-2.2.21-.22 3.83-3.51 3.91-3.81.01-.04.01-.18-.07-.26s-.2-.04-.28-.02c-.12.03-2.09 1.33-5.91 3.91-.56.38-1.06.57-1.52.56-.5-.01-1.46-.28-2.18-.51-.88-.28-1.57-.43-1.51-.91.03-.25.39-.51 1.07-.78 4.18-1.82 6.97-3.02 8.35-3.6 3.99-1.66 4.81-1.95 5.34-1.96.12 0 .38.03.55.17.14.12.18.28.2.44-.01.06.01.23 0 .36z"/>
							</svg>
							<span>Обсудить проект в Telegram</span>
							<svg class="w-5 h-5 ml-2 transform transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
							</svg>
						</a>
						<p class="text-gray-400 text-sm mt-4">Ответ в течение 2 часов</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
