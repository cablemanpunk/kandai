# StudioCMS Database Configuration
# Для локальной разработки используем файловую БД
DATABASE_URL="file:./local.db"

# Для продакшена замените на URL вашей БД
# Пример для Turso (libSQL):
# DATABASE_URL="libsql://your-db-name.turso.io"
# DATABASE_AUTH_TOKEN="your-auth-token"

# Пример для PostgreSQL:
# DATABASE_URL="postgresql://username:password@localhost:5432/dbname"

# Пример для MySQL:
# DATABASE_URL="mysql://username:password@localhost:3306/dbname"

# StudioCMS Configuration
STUDIOCMS_SECRET="your-secret-key-change-this-in-production"
SESSION_SECRET="your-session-secret-change-this-in-production"
